<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MysteryHunter" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent_dim</item>
        <item name="colorOnPrimary">@color/dark_bg</item>
        <item name="colorSecondary">@color/accent_dim</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="android:colorBackground">@color/dark_bg</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/dark_bg</item>
        <item name="android:navigationBarColor">@color/dark_bg</item>
    </style>

    <style name="CardItem" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/dark_card</item>
        <item name="cardCornerRadius">10dp</item>
        <item name="cardElevation">4dp</item>
        <item name="contentPadding">12dp</item>
    </style>
</resources>
